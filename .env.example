# The server intentionally binds to loopback by default.
YT_GAME_HOST=127.0.0.1
YT_GAME_PORT=4310
YT_GAME_WEB_ORIGIN=http://127.0.0.1:5173
YT_GAME_DATA_DIR=./data
YT_GAME_EXPORT_DIR=./exports
YT_GAME_BACKUP_DIR=./backups
YT_GAME_LOG_LEVEL=info
YT_GAME_RETENTION_DAYS=365
# Optional future provider only; leave unset until the YouTube Data API adapter is implemented.
YOUTUBE_API_KEY=
