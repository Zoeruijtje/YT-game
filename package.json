{
  "name": "yt-game",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "concurrently -k -n server,web -c auto \"pnpm --filter @yt-game/server dev\" \"pnpm --filter @yt-game/web dev\"",
    "dev:test": "cross-env YT_GAME_DATA_DIR=.tmp/e2e-data concurrently -k -n server,web -c auto \"pnpm --filter @yt-game/server dev\" \"pnpm --filter @yt-game/web dev --host 127.0.0.1\"",
    "build": "pnpm --filter @yt-game/web build && pnpm --filter @yt-game/server build",
    "start": "pnpm --filter @yt-game/server start",
    "format": "prettier --write .",
    "format:check": "node scripts/format-check.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --exclude tests/browser/**",
    "test:unit": "vitest run packages/domain packages/collectors",
    "test:integration": "vitest run packages/database apps/server",
    "test:browser": "playwright test",
    "db:migrate": "tsx packages/database/src/cli.ts migrate",
    "db:reset": "tsx packages/database/src/cli.ts reset",
    "db:backup": "tsx scripts/maintenance.ts backup",
    "db:purge": "tsx scripts/maintenance.ts purge",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.2",
    "@eslint/js": "^9.25.1",
    "typescript-eslint": "^8.31.0"
  }
}
